# Build environment variables to fix NuGet fallback issues

# Disable NuGet fallback packages
NUGET_FALLBACK_PACKAGES=

# Set explicit package path
NUGET_PACKAGES=%USERPROFILE%\.nuget\packages

# Disable NuGet caching that might reference missing folders
NUGET_NO_CACHE=true

# Disable offline cache
DOTNET_SYSTEM_NET_HTTP_USESOCKETSHTTPHANDLER=0

# Skip first-time experience
DOTNET_SKIP_FIRST_TIME_EXPERIENCE=true
DOTNET_CLI_TELEMETRY_OPTOUT=true
