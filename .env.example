# Database Configuration
DB_SERVER=localhost
DB_NAME=BankApi
DB_USER=sa
DB_PASSWORD=YourSecurePassword123!

# JWT Configuration
JWT_KEY=YourVeryLongAndSecureJWTKeyThatIsAtLeast32CharactersLong

# Email Configuration
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ENABLE_SSL=true
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Deployment Configuration (for MonsterASP or similar hosting)
DEPLOY_URL=https://your-hosting-domain.monsterasp.net/deploy
DEPLOY_USERNAME=your-hosting-username
DEPLOY_PASSWORD=your-hosting-password

# Environment
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000
