# Kubernetes Secrets Template
# DO NOT commit actual secrets to this file or the repository
# This file shows the format required for Kubernetes secrets

# Database Connection
DB_SERVER=database-service
DB_NAME=BankDB
DB_USER=sa
DB_PASSWORD=ChangeMe!SecurePassword123

# JWT Configuration
JWT_KEY=your-very-long-secure-jwt-key-that-is-at-least-32-characters-long-and-complex

# SQL Server SA Password
SA_PASSWORD=ChangeMe!SecurePassword123

# Deployment Instructions:
# 1. Copy this file to secrets.env (NOT committed to git)
# 2. Replace all ChangeMe! values with actual secrets
# 3. Use one of these methods to apply secrets to Kubernetes:
#
#    Option A: Using kubectl from secrets.env
#    kubectl create secret generic bank-secrets \
#      --from-env-file=devops/kubernetes/secrets.env \
#      --namespace=bank-app \
#      -o yaml | kubectl apply -f -
#
#    Option B: Using Sealed Secrets (recommended for production)
#    kubeseal -f secret.yaml -w sealed-secret.yaml
#
#    Option C: Using External Secrets Operator (recommended)
#    Configure ESO to fetch from AWS Secrets Manager, Azure Key Vault, etc.
#
#    Option D: Using Kustomize
#    kustomize edit set image bank-api=bank-api:v1.0.0
#    kustomize build . | kubectl apply -f -
